---
/**
 * Gabarit des pages de LECTURE (cours & articles) :
 * hero (fil d'Ariane, pastilles, titre, chapeau) puis
 *  - avec terminal : colonne ≤66ch à gauche + panneau terminal sticky à droite ;
 *  - sans terminal : colonne unique (largeur technique --measure-wide).
 * Navigation précédent/suivant en pied. Le contenu arrive par <slot/>.
 */
import Base from "./Base.astro";
import Terminal from "../components/Terminal.astro";
import SerieTimeline from "../components/SerieTimeline.astro";

interface NavLink { href: string; label: string }
interface TocItem { slug: string; text: string }
interface Props {
  title: string;
  description?: string;
  crumb: { href: string; label: string };
  badges?: string[];
  /** Pastilles de thématiques (articles) ; `multi` signale la multi-appartenance. */
  topics?: string[];
  lead?: string;
  terminal?: boolean;
  terminalTitle?: string;
  terminalComment?: string;
  /** Sommaire (h2 extraits au rendu) — colonne latérale + double mobile (site.js). */
  toc?: TocItem[];
  /** Timeline de série : un point par module, position courante. */
  serieNav?: { items: { href: string; title: string; num: string }[]; current: number };
  prev?: NavLink;
  next?: NavLink;
  locale?: "fr" | "en";
  altUrl?: string;
}
const {
  title, description, crumb, badges = [], topics = [], lead,
  terminal = false, terminalTitle, terminalComment, toc = [], serieNav, prev, next,
  locale = "fr", altUrl,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base title={title} description={description} progress locale={locale} altUrl={altUrl}>
  <main id="main" class="wrap">
    {/* Le héro est un bandeau pleine largeur AU-DESSUS du sommaire et du
        contenu : son bord gauche est celui de l'enveloppe, insensible aux
        redimensionnements des colonnes en dessous. */}
    <div class="course-hero">
      <div class="course-meta">
        <span class="crumb"><a href={`${base}/`}>~</a> / <a href={crumb.href}>{crumb.label}</a></span>
        {badges.map((b) => <span class="pill">{b}</span>)}
      </div>
      {topics.length > 0 && (
        <ul class="article-tags" aria-label="Thématiques">
          {topics.length > 1 && <li class="multi">↔ {topics.length} thématiques</li>}
          {topics.map((t) => <li>{t}</li>)}
        </ul>
      )}
      <h1>{title}</h1>
      {lead && <p class="lead">{lead}</p>}
      {serieNav && <SerieTimeline items={serieNav.items} current={serieNav.current} locale={locale} />}
    </div>

    <div class:list={[toc.length > 1 && "toc-layout"]} data-swap={toc.length > 1 ? "" : undefined}>
      {toc.length > 1 && (
        <nav
          class="toc"
          aria-label={locale === "en" ? "Table of contents" : "Sommaire"}
          data-swap-grip
          role="button"
          tabindex="0"
          title={locale === "en" ? "Drag to move the table of contents left or right (Enter to toggle)" : "Glisser pour déplacer le sommaire à gauche ou à droite (Entrée pour basculer)"}
        >
          <ol>
            {toc.map((h, i) => (
              <li>
                <a href={`#${h.slug}`}>
                  <span class="num">{String(i + 1).padStart(2, "0")}</span> {h.text}
                </a>
              </li>
            ))}
          </ol>
          {(prev || next) && (
            <div class="toc__nav">
              {prev && <a href={prev.href}><span class="dir" aria-hidden="true">←</span> {prev.label}</a>}
              {next && <a href={next.href}><span class="dir" aria-hidden="true">→</span> {next.label}</a>}
            </div>
          )}
        </nav>
      )}
      <div class="toc-layout__body">
        {terminal ? (
          <div class="course">
            <article class="course__reading prose">
              <slot />
            </article>
            <div class="course__resizer" data-term-resizer role="separator" aria-orientation="vertical" tabindex="0" aria-label={locale === "en" ? "Resize the reading column and the terminal (left/right arrows)" : "Redimensionner la colonne de lecture et le terminal (flèches gauche/droite)"}>
              <span class="knob rz-knob" aria-hidden="true"><i></i><i></i></span>
            </div>
            <aside class="course__aside" aria-label={locale === "en" ? "Terminal workshop" : "Atelier terminal"}>
              <span class="pane-grip">
                <span class="pane-grip__edge t" data-pane-grip role="button" tabindex="0" aria-label={locale === "en" ? "Move the terminal left or right (drag, or Enter)" : "Déplacer le terminal à gauche ou à droite (glisser, ou Entrée)"}>
                  <span class="pane-grip__tip"><span data-lang="fr">Glisser la bordure pour déplacer le terminal</span><span data-lang="en">Drag the border to move the terminal</span></span>
                </span>
                <span class="pane-grip__edge r" data-pane-grip aria-hidden="true"></span>
                <span class="pane-grip__edge b" data-pane-grip aria-hidden="true"></span>
                <span class="pane-grip__edge l" data-pane-grip aria-hidden="true"></span>
              </span>
              <Terminal id="term-1" title={terminalTitle} comment={terminalComment} />
            </aside>
          </div>
        ) : (
          <article class="article course__reading prose">
            <slot />
          </article>
        )}
        {(prev || next) && (
          <nav class:list={["course-nav", !terminal && "article"]} aria-label={locale === "en" ? "Course navigation" : "Navigation du cours"}>
            {prev ? <a class="btn btn--ghost" href={prev.href}>← {prev.label}</a> : <span />}
            {next && <a class="btn btn--primary" href={next.href}>{next.label} →</a>}
          </nav>
        )}
      </div>
    </div>
  </main>
</Base>
