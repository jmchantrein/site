---
/**
 * Gabarit de base : <head> (anti-FOUC, polices locales, styles), en-tête,
 * pied de page, tiroirs de préférences, runtime partagé (site.js).
 * Toute page du site passe par ici — le contenu ne porte jamais le chrome.
 */
import "@fontsource/source-serif-4/400.css";
import "@fontsource/source-serif-4/600.css";
import "@fontsource/source-serif-4/700.css";
import "@fontsource/public-sans/400.css";
import "@fontsource/public-sans/500.css";
import "@fontsource/public-sans/600.css";
import "@fontsource/public-sans/700.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";
import "@fontsource/ibm-plex-mono/700.css";
/* Polices de lecture alternatives — déclarées partout, téléchargées par le
   navigateur uniquement si le lecteur les active (font-face est paresseux). */
import "@fontsource/atkinson-hyperlegible/400.css";
import "@fontsource/atkinson-hyperlegible/700.css";
import "@fontsource/atkinson-hyperlegible/400-italic.css";
import "@fontsource/opendyslexic/400.css";
import "@fontsource/opendyslexic/700.css";
import "@fontsource/opendyslexic/400-italic.css";
import "katex/dist/katex.min.css";
import "../styles/tokens.css";
import "../styles/themes.css";
import "../styles/base.css";
import "../styles/components.css";
import "../styles/a11y-panel.css";
import "../styles/annotate.css";
import "../styles/dock.css";
import Icon from "../components/Icon.astro";
import Panels from "../components/Panels.astro";
import Dock from "../components/Dock.astro";

interface Props {
  title: string;
  description?: string;
  /** Affiche le fil de progression de lecture (pages longues). */
  progress?: boolean;
  /** Langue de la page (une langue = une route ; le contenu EN vit sous /en/). */
  locale?: "fr" | "en";
  /** URL de la même page dans l'autre langue — affiche la bascule FR/EN. */
  altUrl?: string;
}
const { title, description, progress = false, locale = "fr", altUrl } = Astro.props;
const path = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
/* Adresses absolues pour canonical / hreflang / Open Graph. */
const canonical = new URL(path, Astro.site).href;
const altAbs = altUrl ? new URL(altUrl, Astro.site).href : undefined;
/* x-default = la version française (langue par défaut du site). */
const frAbs = locale === "fr" ? canonical : altAbs;
/* Attributs du chrome (aria-label…) : localisés via la prop — le doublon
   data-lang ne vaut que pour le contenu d'élément. */
const A11Y = {
  fr: { progress: "Progression de lecture", nav: "Navigation principale", search: "Rechercher (Ctrl+K)" },
  en: { progress: "Reading progress", nav: "Main navigation", search: "Search (Ctrl+K)" },
}[locale];
const cpfx = locale === "en" ? `${base}/en` : base; // sections traduites
const nav = [
  { href: `${base}/`, fr: "Accueil", en: "Home" },
  { href: `${cpfx}/cours/`, fr: "Cours", en: "Courses" },
  { href: `${cpfx}/miscelanea/`, fr: "Miscelánea", en: "Miscellanea" },
  { href: `${base}/aide/`, fr: "Aide", en: "Help" },
  { href: `${base}/systeme/`, fr: "Système", en: "System" },
];
const isCurrent = (href: string) =>
  href === `${base}/` ? path === href : path.startsWith(href);
---
<!doctype html>
<html lang={locale} data-theme="marine">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Anti-FOUC : applique les préférences AVANT le premier rendu. */}
    <script is:inline>
      (function () {
        try {
          var p = JSON.parse(localStorage.getItem("site-astro-prefs-v1") || "{}");
          var r = document.documentElement;
          var sys = window.matchMedia && matchMedia("(prefers-color-scheme: dark)").matches ? "abysse" : "marine";
          r.setAttribute("data-theme", p.theme || sys);
          if (p.contrast) r.setAttribute("data-contrast", "high");
          if (p.readfont && p.readfont !== "default") r.setAttribute("data-readfont", p.readfont);
          if (p.motion === "off") r.setAttribute("data-motion", "off");
          if (p.width) r.style.setProperty("--page-max", "min(" + p.width + "rem, 98vw)");
          if (p.measure) r.style.setProperty("--measure", p.measure + "ch");
          if (p.scale) r.style.fontSize = p.scale * 100 + "%";
        } catch (e) {}
      })();
    </script>
    <title>{title} — Site Astro</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    {/* Le thème réel suit la préférence système (cf. anti-FOUC) : la couleur
        de la barre du navigateur suit la même logique — Marine / Abysse. */}
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#e9f0f3" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b1a26" />
    <link rel="canonical" href={canonical} />
    {altAbs && <link rel="alternate" hreflang={locale === "fr" ? "en" : "fr"} href={altAbs} />}
    {altAbs && <link rel="alternate" hreflang={locale} href={canonical} />}
    {frAbs && altAbs && <link rel="alternate" hreflang="x-default" href={frAbs} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Site Astro" />
    <meta property="og:locale" content={locale === "en" ? "en_US" : "fr_FR"} />
    {altAbs && <meta property="og:locale:alternate" content={locale === "en" ? "fr_FR" : "en_US"} />}
  </head>
  <body>
    <a class="skip-link" href="#main"><span data-lang="fr">Aller au contenu</span><span data-lang="en">Skip to content</span></a>
    {progress && (
      <div class="read-progress" role="progressbar" aria-label={A11Y.progress} aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
        <div class="read-progress__bar" data-read-progress></div>
      </div>
    )}

    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href={`${base}/`}>
          <span class="brand__mark" aria-hidden="true">$_</span>
          <span class="brand__name">Site Astro<small data-lang="fr">cadre pédagogique</small><small data-lang="en">teaching framework</small></span>
        </a>
        <nav class="site-nav" aria-label={A11Y.nav}>
          {nav.map((item) => (
            <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
              <span data-lang="fr">{item.fr}</span><span data-lang="en">{item.en}</span>
            </a>
          ))}
        </nav>
        <Dock locale={locale} />
        <div class="header-utils">
          {altUrl && (
            <a class="util-btn lang-toggle" href={altUrl} aria-label={locale === "fr" ? "Read this page in English" : "Lire cette page en français"}>
              <Icon name="earth" class="util-btn__icon" />
              <span data-lang-cur>{locale === "fr" ? "EN" : "FR"}</span>
            </a>
          )}
          <button class="util-btn util-btn--icon annot-trigger" data-annot-trigger type="button" aria-expanded="false" aria-haspopup="dialog">
            <Icon name="pen-line" class="util-btn__icon" />
            <span class="annot-count" data-annot-count aria-hidden="true">0</span>
            <span class="util-btn__label"><span data-lang="fr">Mes notes</span><span data-lang="en">My notes</span></span>
          </button>
          <button class="util-btn util-btn--icon" data-search-trigger type="button" aria-label={A11Y.search}>
            <Icon name="search" class="util-btn__icon" />
            <span class="util-btn__label"><span data-lang="fr">Rechercher</span><span data-lang="en">Search</span> <kbd>Ctrl K</kbd></span>
          </button>
          <button class="util-btn util-btn--icon" data-settings-trigger type="button" aria-expanded="false" aria-haspopup="dialog">
            <Icon name="settings" class="util-btn__icon" />
            <span class="util-btn__label"><span data-lang="fr">Paramètres</span><span data-lang="en">Settings</span></span>
          </button>
          <button class="util-btn util-btn--icon" data-a11y-trigger type="button" aria-expanded="false" aria-haspopup="dialog">
            <Icon name="eye" class="util-btn__icon" />
            <span class="util-btn__label"><span data-lang="fr">Accessibilité</span><span data-lang="en">Accessibility</span></span>
          </button>
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="wrap">
        <span class="footer-credit"><span data-lang="fr">Co-conçu avec </span><span data-lang="en">Co-designed with </span><a href="https://claude.ai" target="_blank" rel="noopener">Claude Design</a><span aria-hidden="true"> · </span><a href="https://astro.build" target="_blank" rel="noopener">Astro</a></span>
        <span data-lang="fr">Site Astro — cadre pédagogique fondé sur les sciences cognitives de l'apprentissage (Sweller, Mayer).</span><span data-lang="en">Site Astro — a teaching framework grounded in the cognitive science of learning (Sweller, Mayer).</span>
        <span class="pill">WCAG 2.1 · AA / <span data-lang="fr">corps</span><span data-lang="en">body</span> AAA</span>
        <button class="util-btn footer-a11y" data-a11y-trigger type="button" aria-haspopup="dialog">
          <Icon name="eye" class="util-btn__icon" />
          <span data-lang="fr">Préférences d'accessibilité</span><span data-lang="en">Accessibility preferences</span>
        </button>
      </div>
    </footer>

    <Panels locale={locale} />
    <script src="../scripts/site.js"></script>
    <script src="../scripts/annotate.js"></script>
    <script src="../scripts/dock.js"></script>
    <style>
      .footer-a11y { margin-left: auto; }
      .annot-trigger { position: relative; }
      .annot-count {
        position: absolute; top: -6px; right: -6px;
        min-width: 18px; height: 18px; padding: 0 4px;
        display: grid; place-items: center;
        border-radius: 999px; font-family: var(--font-mono);
        font-size: 11px; font-weight: 700; line-height: 1;
        background: var(--color-accent-text); color: var(--color-on-accent);
      }
      .annot-count[data-n="0"] { display: none; }
    </style>
  </body>
</html>
