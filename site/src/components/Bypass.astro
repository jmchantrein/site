---
/**
 * BYPASS — gabarit d'îlot applicatif (« la paresse de l'informaticien ») :
 * une application JavaScript pédagogique dans un cadre standard — étiquette,
 * titre, plein écran. L'appli elle-même est l'enfant (île Astro ou markup
 * libre) ; le cadre, lui, est toujours le même.
 *
 * Usage MDX :
 *   <Bypass title="Simulateur de masque IP">
 *     <IpSim />
 *   </Bypass>
 */
import Icon from "./Icon.astro";
import { pageLocale } from "../lib/locale";

interface Props {
  /** Nom de l'application affiché dans le chapeau. */
  title: string;
}
const { title } = Astro.props;
const T = {
  fr: { region: `Application interactive : ${title}`, fs: "Plein écran" },
  en: { region: `Interactive application: ${title}`, fs: "Full screen" },
}[pageLocale(Astro.url)];
---
<section class="bypass" data-bypass aria-label={T.region}>
  <div class="bypass__head">
    <span class="bypass__tag"><Icon name="zap" /> bypass</span>
    <span class="bypass__title">{title}</span>
    <button class="bypass__tool" data-bypass-fs type="button" aria-pressed="false" aria-label={T.fs} title={T.fs}>
      <Icon name="expand" />
    </button>
  </div>
  <div class="bypass__body">
    <slot />
  </div>
</section>
