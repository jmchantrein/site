---
/**
 * Pastille de PROVENANCE d'un contenu — définie UNE fois, instanciée par le
 * héro de lecture (Reading.astro) et par la légende d'aide (HelpPage.astro).
 * Réutilise `.pill`. Icône + libellé toujours (jamais la couleur seule) ;
 * petite barre de proportion humain ↔ IA (estimation déclarée, pas une mesure).
 * Le cas « IA non relue par un humain » bascule en mise en garde (.prov--warn).
 */
import Icon from "./Icon.astro";
import { provenanceView, type Provenance } from "../data/provenance";

interface Props {
  provenance: Provenance;
  locale?: "fr" | "en";
  /** Pastille cliquable vers la légende (défaut) ou simple témoin (légende elle-même). */
  link?: boolean;
  /** Version compacte (vignettes) : masque le modèle et la mention de traduction. */
  compact?: boolean;
}
const { provenance, locale = "fr", link = true, compact = false } = Astro.props;
const v = provenanceView(provenance, locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = `${base}${locale === "en" ? "/en/aide/" : "/aide/"}#provenance`;
const Tag = link ? "a" : "span";
---
<Tag class:list={["pill", "prov", v.warn && "prov--warn"]} data-prov={v.key} title={v.title} href={link ? href : undefined}>
  <span class="prov__gauge" aria-hidden="true">
    <Icon name="user" class="prov__pole prov__pole--h" />
    <span class="prov__bar">
      {v.human > 0 && <span class="prov__seg prov__seg--h" style={`flex-grow:${v.human}`}></span>}
      {v.ai > 0 && <span class="prov__seg prov__seg--ai" style={`flex-grow:${v.ai}`}></span>}
    </span>
    <Icon name="bot" class="prov__pole prov__pole--ai" />
  </span>
  {compact
    ? <span class="prov__txt">{v.label}{v.shareText && <span class="prov__share"> · {v.shareText}</span>}</span>
    : <span class="prov__txt">{v.desc}</span>}
</Tag>
