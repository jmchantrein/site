---
/**
 * Icône Lucide inlinée au build (lucide-static) — aucun JS ni CDN au runtime.
 * La taille se règle en CSS sur le conteneur (ex. `.toc svg { width: 16px }`).
 */
import {
  BookOpen,
  Bot,
  ClipboardCopy,
  ChevronLeft,
  ChevronRight,
  Compass,
  Construction,
  Earth,
  Expand,
  Eye,
  FlaskConical,
  HardDrive,
  Layers,
  List,
  Lock,
  Maximize2,
  Boxes,
  EllipsisVertical,
  ExternalLink,
  Grid3x3,
  Minus,
  Moon,
  Network,
  Orbit,
  PenLine,
  RotateCcw,
  Search,
  Settings,
  Sparkles,
  SquareTerminal,
  Sun,
  Timer,
  TriangleAlert,
  Worm,
  X,
  Zap,
} from "lucide-static";

const ICONS: Record<string, string> = {
  "book-open": BookOpen,
  bot: Bot,
  "clipboard-copy": ClipboardCopy,
  "chevron-left": ChevronLeft,
  "chevron-right": ChevronRight,
  compass: Compass,
  construction: Construction,
  earth: Earth,
  expand: Expand,
  eye: Eye,
  "flask-conical": FlaskConical,
  "hard-drive": HardDrive,
  layers: Layers,
  list: List,
  lock: Lock,
  "maximize-2": Maximize2,
  boxes: Boxes,
  "ellipsis-vertical": EllipsisVertical,
  "external-link": ExternalLink,
  grid: Grid3x3,
  minus: Minus,
  moon: Moon,
  network: Network,
  orbit: Orbit,
  "pen-line": PenLine,
  "rotate-ccw": RotateCcw,
  search: Search,
  settings: Settings,
  sparkles: Sparkles,
  "square-terminal": SquareTerminal,
  sun: Sun,
  timer: Timer,
  "triangle-alert": TriangleAlert,
  worm: Worm,
  x: X,
  zap: Zap,
};

interface Props { name: string; class?: string }
const { name, class: cls } = Astro.props;
const raw = ICONS[name];
if (!raw) throw new Error(`Icon « ${name} » absent de la carte ICONS (src/components/Icon.astro)`);
// Icônes toujours décoratives : le sens est porté par un libellé texte (WCAG 1.1.1).
const svg = raw.replace("<svg", '<svg aria-hidden="true" focusable="false"');
---
{cls ? <span class={cls} aria-hidden="true" set:html={svg} /> : <Fragment set:html={svg} />}
