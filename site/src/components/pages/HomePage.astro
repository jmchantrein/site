---
/**
 * Page d'accueil partagée FR/EN : instanciée par src/pages/index.astro
 * (locale "fr") et src/pages/en/index.astro (locale "en").
 */
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { SERIES, courseUnits } from "../../data/series";

interface Props {
  locale?: "fr" | "en";
}
const { locale = "fr" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const cpfx = locale === "en" ? `${base}/en` : base; // sections traduites
const slug = (id: string) => (locale === "en" ? id.slice(3) : id);

/* L'accueil ORIENTE (il ne duplique pas l'onglet Cours) : un pôle par section
   du site — Cours et Miscelánea — avec un contenu phare et un lien « tout
   voir ». Un « cours » = une série de modules (cf. src/data/series.ts). */
const cours = (await getCollection("cours", ({ data, id }) =>
  !data.draft && (locale === "en" ? id.startsWith("en/") : !id.startsWith("en/"))))
  .sort((a, b) => a.data.order - b.data.order);
const units = courseUnits(cours);
// Cours phare = la 1re unité (la série principale, ou le 1er cours autonome).
const u0 = units[0];
const featuredCourse = !u0 ? null : u0.kind === "serie"
  ? { href: `${cpfx}/cours/serie/${u0.serie}/`, title: SERIES[u0.serie][locale], desc: SERIES[u0.serie].desc[locale], meta: `${u0.modules.length} modules` }
  : { href: `${cpfx}/cours/${slug(u0.entry.id)}/`, title: u0.entry.data.title, desc: u0.entry.data.description, meta: u0.entry.data.duration ? `≈ ${u0.entry.data.duration} min` : "" };

const articles = await getCollection("miscelanea", ({ data, id }) =>
  !data.draft && (locale === "en" ? id.startsWith("en/") : !id.startsWith("en/")));
// Fraîcheur = la plus récente des dates connues (publication ou éditions).
const fresh = (dt: { date?: Date; edited?: Date[] }) =>
  Math.max(dt.date?.getTime() ?? 0, ...(dt.edited ?? []).map((e) => e.getTime()));
// Article phare = le plus frais si daté, sinon le 1er par titre (tri stable).
const a0 = [...articles].sort((a, b) =>
  (fresh(b.data) - fresh(a.data)) || a.data.title.localeCompare(b.data.title, locale))[0];
const featuredArticle = !a0 ? null : {
  href: `${cpfx}/miscelanea/${slug(a0.id)}/`,
  title: a0.data.title,
  desc: a0.data.description,
  meta: a0.data.duration ? `≈ ${a0.data.duration} min` : "",
};
---
<Base
  title={locale === "en" ? "Home" : "Accueil"}
  description={locale === "en"
    ? "Structured technical courses and a scientific blog — a teaching framework grounded in the cognitive science of learning, WCAG AA compliant."
    : "Cours techniques structurés et blog scientifique — un cadre pédagogique fondé sur les sciences cognitives de l'apprentissage, conforme WCAG AA."}
  locale={locale}
  altUrl={locale === "fr" ? `${base}/en/` : `${base}/`}
>
  <main id="main">
    <section class="hero wrap">
      <p class="kicker kicker--bar"><span data-lang="fr">Cours &amp; blog technique</span><span data-lang="en">Courses &amp; technical blog</span></p>
      <h1><span data-lang="fr">Des cours techniques expliqués pour être retenus.</span><span data-lang="en">Technical courses explained to be remembered.</span></h1>
      <p class="lead"><span data-lang="fr">Des manuels techniques structurés et un blog scientifique (maths, code, exercices). Chaque décision de mise en forme sert un objectif : réduire la charge cognitive extrinsèque pour que l'attention aille au fond.</span><span data-lang="en">Structured technical manuals and a scientific blog (math, code, exercises). Every design decision serves one goal: cut extraneous cognitive load so attention goes to the substance.</span></p>
      <p class="construction">
        <img src={`${base}/img/construction.gif`} width="232" height="34" alt={locale === "en" ? "Site under construction" : "Site en construction"} />
        <span data-lang="fr">Ce site est en construction — le contenu s'enrichit cours après cours.</span><span data-lang="en">This site is under construction — content grows course after course.</span>
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={`${cpfx}/cours/`}><span data-lang="fr">Commencer les cours</span><span data-lang="en">Start the courses</span> →</a>
        <a class="btn btn--ghost" href={`${base}/systeme/`}><span data-lang="fr">Voir le système de design</span><span data-lang="en">See the design system</span></a>
      </div>

      <div class="principles" aria-label="Principes du cadre">
        <div class="principle">
          <h3><span data-lang="fr">Colonne ≤ 66 caractères</span><span data-lang="en">≤ 66-character column</span></h3>
          <p><span data-lang="fr">La longueur de ligne optimale soutient le suivi visuel.</span><span data-lang="en">Optimal line length supports visual tracking.</span> <code>max-width: 66ch</code></p>
        </div>
        <div class="principle">
          <h3><span data-lang="fr">Corps ≥ 18px, AAA</span><span data-lang="en">Body ≥ 18px, AAA</span></h3>
          <p><span data-lang="fr">Contraste du corps visé à 7:1, jamais en dessous de 4,5:1.</span><span data-lang="en">Body contrast aims for 7:1, never below 4.5:1.</span></p>
        </div>
        <div class="principle">
          <h3><span data-lang="fr">Signalement sobre</span><span data-lang="en">Plain signaling</span></h3>
          <p><span data-lang="fr">Hiérarchie nette, mise en évidence discrète — pas d'esthétique « SaaS ».</span><span data-lang="en">Clear hierarchy, restrained highlighting — no "SaaS" aesthetic.</span></p>
        </div>
        <div class="principle">
          <h3><span data-lang="fr">Réglable par le lecteur</span><span data-lang="en">Reader-adjustable</span></h3>
          <p><span data-lang="fr">Taille, espacement, contraste, mouvement, police — persistants.</span><span data-lang="en">Size, spacing, contrast, motion, font — all persistent.</span></p>
        </div>
      </div>
    </section>

    <section class="wrap explore" aria-label={locale === "en" ? "Explore the site" : "Explorer le site"}>
      <h2 class="explore__title"><span data-lang="fr">Explorer le site</span><span data-lang="en">Explore the site</span></h2>
      <div class="pillars">
        <section class="pillar">
          <div class="pillar__head">
            <h3><span data-lang="fr">Cours</span><span data-lang="en">Courses</span></h3>
            <span class="count">{units.length} <span data-lang="fr">cours</span><span data-lang="en">course(s)</span></span>
          </div>
          <p class="pillar__lead"><span data-lang="fr">Des manuels techniques structurés, du fondamental à l'avancé — un cours, puis ses modules.</span><span data-lang="en">Structured technical manuals, from fundamentals to advanced — a course, then its modules.</span></p>
          {featuredCourse && (
            <a class="module-card" href={featuredCourse.href}>
              <div class="module-card__top">
                <span class="module-card__flag"><span data-lang="fr">Cours principal</span><span data-lang="en">Main course</span></span>
                <span class="module-card__meta">{featuredCourse.meta}</span>
              </div>
              <h4 class="module-card__title">{featuredCourse.title}</h4>
              <p class="module-card__desc">{featuredCourse.desc}</p>
              <span class="module-card__cta"><span data-lang="fr">Ouvrir le cours</span><span data-lang="en">Open the course</span> →</span>
            </a>
          )}
          <a class="btn btn--ghost pillar__all" href={`${cpfx}/cours/`}><span data-lang="fr">Tous les cours</span><span data-lang="en">All courses</span> →</a>
        </section>

        <section class="pillar">
          <div class="pillar__head">
            <h3>Miscelánea</h3>
            <span class="count">{articles.length} <span data-lang="fr">article(s)</span><span data-lang="en">article(s)</span></span>
          </div>
          <p class="pillar__lead"><span data-lang="fr">Des articles courts, scientifiques et techniques — un sujet, droit au but.</span><span data-lang="en">Short scientific and technical articles — one topic, straight to the point.</span></p>
          {featuredArticle && (
            <a class="module-card" href={featuredArticle.href}>
              <div class="module-card__top">
                <span class="module-card__flag"><span data-lang="fr">À lire</span><span data-lang="en">Featured read</span></span>
                {featuredArticle.meta && <span class="module-card__meta">{featuredArticle.meta}</span>}
              </div>
              <h4 class="module-card__title">{featuredArticle.title}</h4>
              <p class="module-card__desc">{featuredArticle.desc}</p>
              <span class="module-card__cta"><span data-lang="fr">Lire l'article</span><span data-lang="en">Read the article</span> →</span>
            </a>
          )}
          <a class="btn btn--ghost pillar__all" href={`${cpfx}/miscelanea/`}><span data-lang="fr">Tous les articles</span><span data-lang="en">All articles</span> →</a>
        </section>
      </div>
    </section>
  </main>
</Base>

<style>
  .hero { padding-block: var(--space-8) var(--space-7); }
  .hero h1 { font-size: clamp(2rem, 5.2vw, 3rem); max-width: 18ch; margin-top: var(--space-4); }
  .hero .lead { margin-top: var(--space-5); max-width: 60ch; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-6); }
  .construction { display: flex; align-items: center; gap: var(--space-4); margin-top: var(--space-5); font-size: var(--text-sm); color: var(--color-text-muted); flex-wrap: wrap; }
  .construction img { image-rendering: pixelated; border-radius: 2px; }
  :global(html[data-motion="off"]) .construction img { display: none; }
  .explore { margin-top: var(--space-7); }
  .explore__title { margin-bottom: var(--space-5); font-size: var(--text-xl); }
  .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-5); align-items: stretch; }
  .pillar { display: flex; flex-direction: column; gap: var(--space-4); padding: var(--space-5); background: var(--color-surface-sunken); border: 1px solid var(--color-border); border-radius: var(--radius-lg); }
  .pillar__head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-3); flex-wrap: wrap; }
  .pillar__head h3 { margin: 0; font-size: var(--text-xl); }
  .pillar__head .count { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-text-muted); }
  .pillar__lead { margin: 0; color: var(--color-text-muted); font-size: var(--text-base); max-width: none; }
  .pillar__all { align-self: flex-start; margin-top: auto; }
  .module-card__flag { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: var(--weight-semibold); color: var(--color-accent-text); text-transform: uppercase; letter-spacing: 0.04em; }
  .principles { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-5); margin-block: var(--space-6); max-width: none; }
  .principle { padding-top: var(--space-4); border-top: 2px solid var(--color-accent); }
  .principle h3 { font-size: var(--text-md); margin: 0 0 var(--space-2); }
  .principle p { font-size: var(--text-sm); color: var(--color-text-muted); max-width: 34ch; margin: 0; }
  .principle code { font-size: 0.85em; }
</style>
