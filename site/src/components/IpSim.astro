---
/**
 * SIMULATEUR DE MASQUE IP — îlot interactif autonome.
 * IPv4 + préfixe CIDR → règle de 32 bits colorée (réseau/hôte), masque,
 * adresse réseau, diffusion, plage d'hôtes, nombre d'hôtes — en direct.
 * Tout est local (aucune dépendance) ; gère /31 (RFC 3021) et /32.
 */
import Icon from "./Icon.astro";
---
<section class="ipsim" data-ipsim aria-label="Simulateur de masque IP">
  <div class="ipsim__head">
    <span class="tag"><Icon name="network" /> <span data-lang="fr">Simulateur de masque</span><span data-lang="en">Mask simulator</span></span>
  </div>
  <div class="ipsim__body">
    <div class="ipsim__controls">
      <div class="ipsim__field">
        <label for="ipsim-ip"><span data-lang="fr">Adresse IPv4</span><span data-lang="en">IPv4 address</span></label>
        <input id="ipsim-ip" class="ipsim__ip" type="text" inputmode="decimal" autocomplete="off" spellcheck="false" value="192.168.1.130" data-ipsim-ip aria-label="Adresse IPv4" />
      </div>
      <div class="ipsim__field">
        <label for="ipsim-prefix"><span data-lang="fr">Préfixe CIDR</span><span data-lang="en">CIDR prefix</span></label>
        <div class="ipsim__prefix">
          <span class="ipsim__cidr" data-ipsim-cidr>/24</span>
          <input id="ipsim-prefix" type="range" min="0" max="32" step="1" value="24" data-ipsim-prefix aria-label="Préfixe CIDR" />
        </div>
      </div>
    </div>

    <div>
      <div class="ipsim__bits" data-ipsim-bits aria-hidden="true"></div>
      <div class="ipsim__legend">
        <span><i class="k-net"></i> <span data-lang="fr">bits réseau</span><span data-lang="en">network bits</span></span>
        <span><i class="k-host"></i> <span data-lang="fr">bits hôte</span><span data-lang="en">host bits</span></span>
      </div>
    </div>

    <div class="ipsim__out">
      <div class="ipsim__cell"><div class="lbl"><span data-lang="fr">Masque</span><span data-lang="en">Mask</span></div><div class="val" data-ipsim-mask>255.255.255.0</div></div>
      <div class="ipsim__cell"><div class="lbl"><span data-lang="fr">Adresse réseau</span><span data-lang="en">Network</span></div><div class="val accent" data-ipsim-network>192.168.1.0</div></div>
      <div class="ipsim__cell"><div class="lbl"><span data-lang="fr">Diffusion</span><span data-lang="en">Broadcast</span></div><div class="val" data-ipsim-broadcast>192.168.1.255</div></div>
      <div class="ipsim__cell"><div class="lbl"><span data-lang="fr">Plage d'hôtes</span><span data-lang="en">Host range</span></div><div class="val" data-ipsim-range>192.168.1.1 – .254</div></div>
      <div class="ipsim__cell"><div class="lbl"><span data-lang="fr">Hôtes utilisables</span><span data-lang="en">Usable hosts</span></div><div class="val accent" data-ipsim-hosts>254</div></div>
    </div>
  </div>
  <div class="ipsim__foot">
    <span data-lang="fr">Modifiez l'adresse ou faites glisser le préfixe : la frontière réseau/hôte se déplace en direct.</span><span data-lang="en">Change the address or drag the prefix: the network/host boundary moves live.</span>
  </div>
</section>

<style>
  .ipsim { max-width: var(--measure-wide); margin-block: var(--space-6); border: 1px solid var(--color-border-strong); border-radius: var(--radius-lg); background: var(--color-surface); box-shadow: var(--shadow-1); overflow: hidden; }
  .ipsim__head { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-5); background: var(--color-surface-sunken); border-bottom: 1px solid var(--color-border); }
  .ipsim__head .tag { font-family: var(--font-mono); font-weight: 700; font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-accent-text); display: inline-flex; gap: var(--space-2); align-items: center; }
  .ipsim__head .tag :global(svg) { width: 18px; height: 18px; }
  .ipsim__body { padding: var(--space-5); display: grid; gap: var(--space-5); }
  .ipsim__controls { display: grid; gap: var(--space-4); grid-template-columns: 1fr; }
  @media (min-width: 620px) { .ipsim__controls { grid-template-columns: auto 1fr; align-items: center; gap: var(--space-4) var(--space-6); } }
  .ipsim__field label { display: block; font-weight: var(--weight-semibold); color: var(--color-text-strong); margin-bottom: var(--space-2); font-size: var(--text-sm); }
  .ipsim__ip { font-family: var(--font-mono); font-size: var(--text-md); width: 100%; max-width: 18ch; padding: var(--space-2) var(--space-3); border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); background: var(--color-bg); color: var(--color-text); }
  .ipsim__ip:focus-visible { outline: var(--focus-ring); outline-offset: 1px; border-color: var(--color-accent); }
  .ipsim__prefix { display: flex; align-items: center; gap: var(--space-3); }
  .ipsim__prefix input[type="range"] { flex: 1; accent-color: var(--color-accent); height: 32px; }
  .ipsim__cidr { font-family: var(--font-mono); font-weight: 700; font-size: var(--text-lg); color: var(--color-accent-text); min-width: 3.2ch; text-align: center; }

  /* règle binaire 32 bits — UN OCTET PAR LIGNE (lisibilité pédagogique) */
  .ipsim__bits { display: grid; gap: var(--space-2); font-family: var(--font-mono); justify-content: start; }
  .ipsim__bits :global(.ipsim__octet) { display: flex; gap: 2px; align-items: center; flex-wrap: nowrap; }
  .ipsim__bits :global(.ipsim__dec) { margin-left: var(--space-3); font-size: var(--text-sm); color: var(--color-text-muted); white-space: nowrap; }
  .ipsim__bits :global(.ipsim__dec b) { color: var(--color-text-strong); }
  .ipsim__bits :global(.ipsim__bit) { width: 1.55em; height: 2em; display: grid; place-items: center; border-radius: 3px; font-size: 0.95rem; font-weight: 600; border: 1px solid transparent; position: relative; }
  .ipsim__bits :global(.ipsim__bit.net) { background: color-mix(in srgb, var(--color-accent) 30%, transparent); color: var(--color-text-strong); border-color: color-mix(in srgb, var(--color-accent) 55%, transparent); }
  .ipsim__bits :global(.ipsim__bit.host) { background: var(--color-surface-sunken); color: var(--color-text-muted); border-color: var(--color-border); }
  .ipsim__bits :global(.ipsim__bit.boundary) { box-shadow: -3px 0 0 var(--color-warning); }
  .ipsim__legend { display: flex; flex-wrap: wrap; gap: var(--space-4); font-size: var(--text-sm); color: var(--color-text-muted); margin-top: var(--space-3); }
  .ipsim__legend span { display: inline-flex; align-items: center; gap: var(--space-2); }
  .ipsim__legend i { width: 14px; height: 14px; border-radius: 3px; display: inline-block; }
  .ipsim__legend .k-net { background: color-mix(in srgb, var(--color-accent) 30%, transparent); border: 1px solid color-mix(in srgb, var(--color-accent) 55%, transparent); }
  .ipsim__legend .k-host { background: var(--color-surface-sunken); border: 1px solid var(--color-border); }

  .ipsim__out { display: grid; gap: var(--space-3); grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .ipsim__cell { border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-3) var(--space-4); background: var(--color-bg); }
  .ipsim__cell .lbl { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: var(--font-mono); }
  .ipsim__cell .val { font-family: var(--font-mono); font-size: var(--text-md); color: var(--color-text-strong); margin-top: 2px; word-break: break-all; }
  .ipsim__cell .val.accent { color: var(--color-accent-text); }
  .ipsim__foot { border-top: 1px solid var(--color-border); color: var(--color-text-muted); padding: var(--space-2) var(--space-5); font-size: var(--text-xs); }
</style>

<script>
  // Calcul 32 bits, mise à jour live.
  document.querySelectorAll("[data-ipsim]").forEach((box) => {
    const ipIn = box.querySelector("[data-ipsim-ip]");
    const pfIn = box.querySelector("[data-ipsim-prefix]");
    const cidr = box.querySelector("[data-ipsim-cidr]");
    const bitsEl = box.querySelector("[data-ipsim-bits]");
    const out = {
      mask: box.querySelector("[data-ipsim-mask]"),
      network: box.querySelector("[data-ipsim-network]"),
      broadcast: box.querySelector("[data-ipsim-broadcast]"),
      range: box.querySelector("[data-ipsim-range]"),
      hosts: box.querySelector("[data-ipsim-hosts]"),
    };
    function parseIp(s) {
      const p = (s || "").trim().split(".");
      if (p.length !== 4) return null;
      let n = 0;
      for (let i = 0; i < 4; i++) {
        const x = Number(p[i]);
        if (p[i] === "" || isNaN(x) || x < 0 || x > 255 || !/^\d+$/.test(p[i])) return null;
        n = (n << 8) | x;
      }
      return n >>> 0;
    }
    const dotted = (n) => [(n >>> 24) & 255, (n >>> 16) & 255, (n >>> 8) & 255, n & 255].join(".");
    function render() {
      const p = parseInt(pfIn.value, 10);
      cidr.textContent = "/" + p;
      const ip = parseIp(ipIn.value);
      const valid = ip !== null;
      ipIn.style.borderColor = valid ? "" : "var(--color-danger)";
      const mask = p === 0 ? 0 : (0xffffffff << (32 - p)) >>> 0;
      let html = "";
      const base = valid ? ip : 0;
      for (let oct = 0; oct < 4; oct++) {
        html += '<span class="ipsim__octet">';
        for (let b = 0; b < 8; b++) {
          const idx = oct * 8 + b;
          const bit = (base >>> (31 - idx)) & 1;
          const isNet = idx < p;
          const boundary = idx === p && p > 0 && p < 32 ? " boundary" : "";
          html += '<span class="ipsim__bit ' + (isNet ? "net" : "host") + boundary + '">' + bit + "</span>";
        }
        // valeur décimale de l'octet en bout de ligne
        const dec = (base >>> (8 * (3 - oct))) & 255;
        html += '<span class="ipsim__dec">= <b>' + dec + "</b></span></span>";
      }
      bitsEl.innerHTML = html;
      if (!valid) { out.mask.textContent = dotted(mask); out.network.textContent = "—"; out.broadcast.textContent = "—"; out.range.textContent = "—"; out.hosts.textContent = "—"; return; }
      const network = (ip & mask) >>> 0;
      const broadcast = (network | (~mask >>> 0)) >>> 0;
      out.mask.textContent = dotted(mask);
      out.network.textContent = dotted(network);
      out.broadcast.textContent = dotted(broadcast);
      if (p >= 32) { out.range.textContent = dotted(network) + " (" + (document.documentElement.lang === "en" ? "single host" : "hôte unique") + ")"; out.hosts.textContent = "1"; }
      else if (p === 31) { out.range.textContent = dotted(network) + " – " + dotted(broadcast); out.hosts.textContent = "2"; }
      else {
        out.range.textContent = dotted((network + 1) >>> 0) + " – " + dotted((broadcast - 1) >>> 0);
        out.hosts.textContent = String(Math.pow(2, 32 - p) - 2);
      }
    }
    ipIn.addEventListener("input", render);
    pfIn.addEventListener("input", render);
    render();
  });
</script>
