---
/**
 * DIAPORAMA — îlot « slides » : navigation précédent/suivant, points, compteur,
 * clavier ←/→, vue étendue (pop-up) et plein écran. Peut contenir un PDF ou
 * tout média via <Slide media>.
 *
 * Usage MDX :
 *   <Slides title="Cycle de vie">
 *     <Slide>### 1. create …</Slide>
 *     <Slide media><iframe src="…" /></Slide>
 *   </Slides>
 */
import Icon from "./Icon.astro";
import { pageLocale } from "../lib/locale";

interface Props {
  /** Titre affiché dans le chapeau (ex. « Diaporama — cycle de vie »). */
  title: string;
}
const { title } = Astro.props;
const T = {
  fr: { region: `Diaporama : ${title}`, role: "diaporama", expand: "Vue étendue", fs: "Plein écran", prev: "Diapositive précédente", next: "Diapositive suivante", dots: "Diapositives" },
  en: { region: `Slideshow: ${title}`, role: "slideshow", expand: "Expanded view", fs: "Full screen", prev: "Previous slide", next: "Next slide", dots: "Slides" },
}[pageLocale(Astro.url)];
---
{/* role="group" : aria-roledescription exige un rôle explicite. Les points de
    navigation sont un simple groupe de boutons (aria-current), pas un tablist
    ARIA — il n'y a pas de tabpanels associés. */}
<section class="slides" data-slides tabindex="0" role="group" aria-roledescription={T.role} aria-label={T.region}>
  <div class="slides__head">
    <span class="slides__tag"><Icon name="layers" /> {title}</span>
    <span class="slides__counter" data-slides-counter aria-hidden="true"></span>
    <span class="slides__tools">
      <button class="slides__tool" data-slides-expand type="button" aria-pressed="false" aria-label={T.expand} title={T.expand}><Icon name="maximize-2" /></button>
      <button class="slides__tool" data-slides-fs type="button" aria-pressed="false" aria-label={T.fs} title={T.fs}><Icon name="expand" /></button>
    </span>
  </div>
  <div class="slides__viewport">
    <div class="slides__track" data-slides-track>
      <slot />
    </div>
  </div>
  <div class="slides__foot">
    <button class="slides__btn" data-slides-prev type="button" aria-label={T.prev}><Icon name="chevron-left" /></button>
    <span class="slides__dots" data-slides-dots role="group" aria-label={T.dots}></span>
    <button class="slides__btn" data-slides-next type="button" aria-label={T.next}><Icon name="chevron-right" /></button>
  </div>
</section>
