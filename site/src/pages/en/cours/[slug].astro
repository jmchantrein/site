---
import { getCollection, render } from "astro:content";
import Reading from "../../../layouts/Reading.astro";
import { mdxComponents } from "../../../components/mdx";
import { SERIES, serieNumbers } from "../../../data/series";

export async function getStaticPaths() {
  // Traductions anglaises : sous-dossier en/ de la collection (CLAUDE.md).
  const cours = (await getCollection("cours", ({ data, id }) => !data.draft && id.startsWith("en/")))
    .sort((a, b) => a.data.order - b.data.order);
  const nums = serieNumbers(cours);
  return cours.map((entry) => {
    const chain = entry.data.serie ? cours.filter((c) => c.data.serie === entry.data.serie) : [entry];
    const i = chain.indexOf(entry);
    return {
      params: { slug: entry.id.slice(3) },
      props: {
        entry, prevEntry: chain[i - 1] ?? null, nextEntry: chain[i + 1] ?? null, mod: nums.get(entry.id) ?? null,
        serieItems: entry.data.serie
          ? chain.map((c) => ({ id: c.id.slice(3), title: c.data.title, num: nums.get(c.id)?.num ?? "" }))
          : null,
        serieIndex: i,
      },
    };
  });
}

const { entry, prevEntry, nextEntry, mod, serieItems, serieIndex } = Astro.props;
const { Content, headings } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const slug = entry.id.slice(3);
const d = entry.data;
const badges = [d.badge, d.duration ? `≈ ${d.duration} min` : null].filter(Boolean) as string[];
const toc = headings.filter((h) => h.depth === 2).map((h) => ({ slug: h.slug, text: h.text }));
const crumbLabel = mod ? `${SERIES[mod.serie].en} · module ${mod.num}/${String(mod.total).padStart(2, "0")}` : "course";
// Le fil d'Ariane remonte AU COURS (la série), pas à l'index plat.
const crumbHref = mod ? `${base}/en/cours/serie/${mod.serie}/` : `${base}/en/cours/`;
const serieNav = serieItems
  ? { items: serieItems.map((m) => ({ href: `${base}/en/cours/${m.id}/`, title: m.title, num: m.num })), current: serieIndex }
  : undefined;
---
<Reading
  title={d.title}
  description={d.description}
  crumb={{ href: crumbHref, label: crumbLabel }}
  badges={badges}
  lead={d.description}
  provenance={d.provenance}
  status={d.status}
  terminal={d.terminal}
  terminalTitle={d.terminalTitle}
  terminalComment={d.terminalComment}
  toc={toc}
  serieNav={serieNav}
  locale="en"
  altUrl={`${base}/cours/${slug}/`}
  prev={prevEntry
    ? { href: `${base}/en/cours/${prevEntry.id.slice(3)}/`, label: prevEntry.data.title }
    : { href: `${base}/en/cours/`, label: "All courses" }}
  next={nextEntry
    ? { href: `${base}/en/cours/${nextEntry.id.slice(3)}/`, label: `Next module: ${nextEntry.data.title}` }
    : { href: `${base}/en/cours/`, label: "All courses" }}
>
  <Content components={mdxComponents} />
</Reading>
