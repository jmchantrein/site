---
import { getCollection, render } from "astro:content";
import Reading from "../../../layouts/Reading.astro";
import { mdxComponents } from "../../../components/mdx";
import { TOPICS } from "../../../data/topics";

export async function getStaticPaths() {
  const articles = await getCollection("miscelanea", ({ data, id }) => !data.draft && id.startsWith("en/"));
  // La bascule de langue n'est proposée que si la page FR existe.
  const frIds = new Set((await getCollection("miscelanea", ({ id }) => !id.startsWith("en/"))).map((a) => a.id));
  return articles.map((entry) => ({
    params: { slug: entry.id.slice(3) },
    props: { entry, hasFr: frIds.has(entry.id.slice(3)) },
  }));
}

const { entry, hasFr } = Astro.props;
const { Content, headings } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const slug = entry.id.slice(3);
const d = entry.data;
const updated = d.edited?.length ? d.edited.reduce((a, b) => (b > a ? b : a)) : undefined;
const dates = { published: d.date, updated };
const toc = headings.filter((h) => h.depth === 2).map((h) => ({ slug: h.slug, text: h.text }));
---
<Reading
  title={d.title}
  description={d.description}
  crumb={{ href: `${base}/en/miscelanea/`, label: "Miscelánea" }}
  badges={d.duration ? [`≈ ${d.duration} min`] : []}
  topics={d.topics.map((t) => TOPICS[t])}
  lead={d.description}
  provenance={d.provenance}
  dates={dates}
  status={d.status}
  toc={toc}
  locale="en"
  altUrl={hasFr ? `${base}/miscelanea/${slug}/` : undefined}
  prev={{ href: `${base}/en/miscelanea/`, label: "All articles" }}
>
  <Content components={mdxComponents} />
</Reading>
