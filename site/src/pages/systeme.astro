---
import Base from "../layouts/Base.astro";
import Note from "../components/Note.astro";
import Exercise from "../components/Exercise.astro";
import Cmd from "../components/Cmd.astro";
import TermLine from "../components/TermLine.astro";
import Terminal from "../components/Terminal.astro";
import Slides from "../components/Slides.astro";
import Slide from "../components/Slide.astro";
import Escape from "../components/Escape.astro";

/* Pastilles de couleurs annotées (ratios calculés sur le fond Abysse, défaut). */
const swatches = [
  { v: "--color-bg", name: "bg", note: "fond — bleu-vert très sombre" },
  { v: "--color-surface", name: "surface", note: "cartes / panneaux" },
  { v: "--color-text", name: "text", note: "corps · ~14:1 → AAA" },
  { v: "--color-text-muted", name: "text-muted", note: "méta · ~8:1 → AAA" },
  { v: "--color-accent-text", name: "accent-text", note: "liens · ~9:1 → AAA" },
  { v: "--color-success", name: "success", note: "~10:1 → AAA (toujours doublé d'un label)" },
  { v: "--color-warning", name: "warning", note: "~9:1 → AAA (idem)" },
  { v: "--color-danger", name: "danger", note: "~7:1 → AAA (idem)" },
];
const refs = [
  { t: "Théorie de la charge cognitive (Sweller)", url: "https://fr.wikipedia.org/wiki/Th%C3%A9orie_de_la_charge_cognitive" },
  { t: "Apprentissage multimédia (Mayer)", url: "https://en.wikipedia.org/wiki/E-learning_(theory)" },
  { t: "Effet de test (testing effect)", url: "https://fr.wikipedia.org/wiki/Effet_de_test" },
  { t: "WCAG 2.1 — 1.4.3 / 1.4.6 (contraste)", url: "https://www.w3.org/WAI/WCAG21/Understanding/contrast-minimum.html" },
  { t: "WCAG 2.1 — 1.4.12 (espacement du texte)", url: "https://www.w3.org/WAI/WCAG21/Understanding/text-spacing.html" },
  { t: "WCAG 2.1 — 2.3.3 (animations)", url: "https://www.w3.org/WAI/WCAG21/Understanding/animation-from-interactions.html" },
];
---
<Base title="Système de design" description="Tokens annotés, composants contraints et leurs variantes : le cadre pédagogique documenté, avec ses fondements scientifiques." progress>
  <main id="main" class="wrap">
    <div class="ds-hero">
      <p class="kicker kicker--bar"><span data-lang="fr">Système de design — co-conçu avec <a href="https://claude.ai" target="_blank" rel="noopener">Claude Design</a></span><span data-lang="en">Design system — co-designed with <a href="https://claude.ai" target="_blank" rel="noopener">Claude Design</a></span></p>
      <h1><span data-lang="fr">Le design comme cadre pédagogique</span><span data-lang="en">Design as a teaching framework</span></h1>
      <p class="lead"><span data-lang="fr">La forme agit sur l'apprentissage : tout ce qui coûte de l'attention sans servir le fond (décor, incohérences, lignes trop longues) est de la charge cognitive extrinsèque. Ce système encode les bonnes pratiques dans des composants contraints : écrire un cours respecte automatiquement les recommandations.</span><span data-lang="en">Form acts on learning: anything that costs attention without serving substance is extraneous cognitive load. This system encodes good practice into constrained components: writing a course automatically follows the recommendations.</span></p>
      <p><span data-lang="fr">Un <strong>token</strong> est une variable de design nommée — couleur, taille, espacement, largeur — définie en un seul endroit et réutilisée partout : la changer propage l'effet à tout le site sans toucher au contenu.</span><span data-lang="en">A <strong>token</strong> is a named design variable — colour, size, spacing, width — defined in one place and reused everywhere: changing it propagates to the whole site without touching content.</span></p>
    </div>

    <div class="toc-layout" style="--toc-col: 230px">
      <nav class="toc" aria-label="Sommaire">
        <ol>
          <li><a href="#couleurs"><span class="num">01</span>Couleurs</a></li>
          <li><a href="#typo"><span class="num">02</span>Typographie &amp; colonnes</a></li>
          <li><a href="#notes"><span class="num">03</span>Notes</a></li>
          <li><a href="#exercices"><span class="num">04</span>Exercices</a></li>
          <li><a href="#terminal"><span class="num">05</span>Commande &amp; terminal</a></li>
          <li><a href="#diaporama"><span class="num">06</span>Diaporama</a></li>
          <li><a href="#trappe"><span class="num">07</span>Trappe d'évasion</a></li>
          <li><a href="#reglages"><span class="num">08</span>Accessibilité &amp; réglages</a></li>
          <li><a href="#references"><span class="num">09</span>Références</a></li>
        </ol>
      </nav>

      <div class="prose ds-body">
        <section class="ds-section" id="couleurs">
          <h2>01 · Couleurs</h2>
          <p>Cinq thèmes ne redéfinissent <em>que</em> les tokens de couleur (<code>themes.css</code>) ; tout le reste suit. Défaut : <strong>Abysse</strong> (sombre). Chaque valeur est annotée de son ratio de contraste WCAG dans <code>tokens.css</code>. L'information n'est <strong>jamais portée par la couleur seule</strong> : chaque état sémantique est doublé d'une icône et d'un libellé.</p>
          <div class="ds-swatches">
            {swatches.map((s) => (
              <div class="ds-swatch">
                <span class="chip" style={`background: var(${s.v})`}></span>
                <code>{s.name}</code>
                <small>{s.note}</small>
              </div>
            ))}
          </div>
        </section>

        <section class="ds-section" id="typo">
          <h2>02 · Typographie &amp; colonnes</h2>
          <ul>
            <li><strong>Serif</strong> (Source Serif 4) pour les titres — signalement et hiérarchie ;</li>
            <li><strong>Sans</strong> à forte hauteur d'x (Public Sans) pour le corps — <strong>18 px plancher</strong>, interligne 1,6 ;</li>
            <li><strong>Mono</strong> (IBM Plex Mono) pour code, méta et terminal.</li>
          </ul>
          <p>La colonne de lecture est plafonnée à <code>max-width: 66ch</code> — règle, pas suggestion. Les zones techniques (tableaux, code) montent à <code>78ch</code>. L'espacement suit une échelle en base 8 px : la segmentation en blocs courts réduit la charge extrinsèque.</p>
        </section>

        <section class="ds-section" id="notes">
          <h2>03 · Notes (admonitions)</h2>
          <p>Un encart qui détache du texte une information à signaler. Quatre variantes, chacune combinant <em>couleur + icône + libellé</em> (WCAG 1.4.1) :</p>
          <Note>Variante <code>info</code> (défaut) — précision ou prérequis.</Note>
          <Note type="success" title="Astuce">Variante <code>success</code> — raccourci ou bonne pratique.</Note>
          <Note type="warning">Variante <code>warning</code> — point de vigilance.</Note>
          <Note type="danger" title="Piège">Variante <code>danger</code> — erreur fréquente aux conséquences réelles.</Note>
        </section>

        <section class="ds-section" id="exercices">
          <h2>04 · Exercices</h2>
          <p>Structure imposée : énoncé visible → solution repliable, masquée par défaut (<em>effet de test</em>). Le champ réponse <strong>verrouille la solution tant qu'il est vide</strong> — réglage global dans Paramètres, forçable par bloc. Trois niveaux documentés.</p>
          <Exercise id="demo-systeme" level={1}>
            <p>Spécimen : que vaut 2⁶ − 2 ? (Tapez une réponse pour déverrouiller la solution.)</p>
            <Fragment slot="solution"><p>2⁶ − 2 = 62. Dans les contenus MDX, les maths s'écrivent <code>$…$</code> et sont rendues par KaTeX au build — aucun script tiers au runtime.</p></Fragment>
          </Exercise>
        </section>

        <section class="ds-section" id="terminal">
          <h2>05 · Commande cliquable &amp; terminal</h2>
          <p>La commande s'« exécute » dans le panneau terminal (frappe animée, sortie simulée et étiquetée). Le terminal accepte aussi la <strong>saisie directe</strong> (<code>help</code>, historique ↑/↓), se bascule en clair/sombre localement et se réinitialise.</p>
          <Cmd cmd="uname -r" term="#term-demo">
            <TermLine>6.8.0-1-amd64</TermLine>
            <TermLine type="ok" tag="note">un seul noyau, partagé par tous les conteneurs.</TermLine>
          </Cmd>
          <Terminal id="term-demo" title="bash — démo" comment="# démo — tapez « help » ou cliquez la commande ci-dessus" />
        </section>

        <section class="ds-section" id="diaporama">
          <h2>06 · Diaporama</h2>
          <p>Îlot de diapositives : flèches, points, compteur, clavier ←/→, <strong>vue étendue</strong> (pop-up) et <strong>plein écran</strong>. Une diapositive « média » peut accueillir un PDF plein cadre.</p>
          <Slides title="Diaporama — démo">
            <Slide><h3>Diapositive 1</h3><p>Navigation par flèches, points, ou clavier.</p></Slide>
            <Slide><h3>Diapositive 2</h3><p>Vue étendue et plein écran via les outils du chapeau.</p></Slide>
          </Slides>
        </section>

        <section class="ds-section" id="trappe">
          <h2>07 · Trappe d'évasion</h2>
          <p>Le cadre se désactive <em>explicitement et visiblement</em> : bordure pointillée, hachures, levée du plafond de colonne. C'est la soupape officielle pour le contenu hors gabarit (visualisation custom, HTML/JS libre).</p>
          <Escape>
            <h3 style="margin-top:0">Zone libre</h3>
            <p>Ici, aucune contrainte de colonne ni de composant n'est imposée.</p>
          </Escape>
        </section>

        <section class="ds-section" id="reglages">
          <h2>08 · Accessibilité &amp; réglages</h2>
          <p>Deux tiroirs distincts, persistants (<code>localStorage</code>) et appliqués avant le premier rendu (anti-flash) :</p>
          <ul>
            <li><strong>Accessibilité</strong> (œil) — taille du texte, interligne, espacements lettres/mots jusqu'aux seuils WCAG 1.4.12, contraste élevé (prime sur le thème), réduction des animations (WCAG 2.3.3, double <code>prefers-reduced-motion</code>), police de lecture Atkinson/OpenDyslexic.</li>
            <li><strong>Paramètres</strong> (roue crantée) — thème de couleurs, verrou des exercices, largeur du site, langue FR/EN.</li>
          </ul>
          <p>S'y ajoutent : recherche locale <kbd>Ctrl</kbd>+<kbd>K</kbd> (index généré au build), fil de progression de lecture, ancres copiables au survol des titres, sommaire mobile généré depuis la même source.</p>
        </section>

        <section class="ds-section" id="references">
          <h2>09 · Références</h2>
          <p>Les principes que ce système encode, avec leurs sources :</p>
          <ul class="ds-refs">
            {refs.map((r) => <li><a href={r.url} target="_blank" rel="noopener">{r.t}</a></li>)}
          </ul>
        </section>
      </div>
    </div>
  </main>
</Base>

<style>
  .ds-hero { padding-block: var(--space-7) var(--space-5); border-bottom: 1px solid var(--color-border); }
  .ds-hero h1 { font-size: clamp(2rem, 4.5vw, var(--text-2xl)); max-width: 22ch; margin-top: var(--space-3); }
  .ds-hero .lead { margin-top: var(--space-4); }
  .ds-hero p:last-child { margin-top: var(--space-4); max-width: var(--measure); }
  .toc-layout { padding-block: var(--space-6); }
  .ds-section { scroll-margin-top: 80px; padding-block: var(--space-5); border-top: 1px solid var(--color-border); }
  .ds-section:first-child { border-top: none; }
  .ds-swatches { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: var(--space-3); margin-top: var(--space-4); max-width: var(--measure-wide); }
  .ds-swatch { display: grid; grid-template-columns: 34px 1fr; grid-template-rows: auto auto; gap: 2px var(--space-3); align-items: center; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-3); background: var(--color-surface); }
  .ds-swatch .chip { grid-row: 1 / 3; width: 34px; height: 34px; border-radius: var(--radius-sm); border: 1px solid var(--color-border-strong); }
  .ds-swatch small { color: var(--color-text-muted); font-size: var(--text-xs); }
  .ds-refs li { margin-top: var(--space-2); }
</style>
