---
import { getCollection, render } from "astro:content";
import Reading from "../../layouts/Reading.astro";
import { mdxComponents } from "../../components/mdx";
import { SERIES, serieNumbers } from "../../data/series";

export async function getStaticPaths() {
  const all = await getCollection("cours", ({ data }) => !data.draft);
  // FR à la racine de la collection ; les traductions vivent sous en/ (routes /en/).
  const cours = all.filter((c) => !c.id.startsWith("en/")).sort((a, b) => a.data.order - b.data.order);
  const enIds = new Set(all.filter((c) => c.id.startsWith("en/")).map((c) => c.id.slice(3)));
  const nums = serieNumbers(cours);
  return cours.map((entry) => {
    // Précédent/suivant À L'INTÉRIEUR de la série (un cours = ses modules) ;
    // un cours autonome n'a pas de chaîne.
    const chain = entry.data.serie ? cours.filter((c) => c.data.serie === entry.data.serie) : [entry];
    const i = chain.indexOf(entry);
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prevEntry: chain[i - 1] ?? null,
        nextEntry: chain[i + 1] ?? null,
        hasEn: enIds.has(entry.id),
        mod: nums.get(entry.id) ?? null,
        serieItems: entry.data.serie
          ? chain.map((c) => ({ id: c.id, title: c.data.title, num: nums.get(c.id)?.num ?? "" }))
          : null,
        serieIndex: i,
      },
    };
  });
}

const { entry, prevEntry, nextEntry, hasEn, mod, serieItems, serieIndex } = Astro.props;
const { Content, headings } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const d = entry.data;
const badges = [d.badge, d.duration ? `≈ ${d.duration} min` : null].filter(Boolean) as string[];
const toc = headings.filter((h) => h.depth === 2).map((h) => ({ slug: h.slug, text: h.text }));
const crumbLabel = mod ? `${SERIES[mod.serie].fr} · module ${mod.num}/${String(mod.total).padStart(2, "0")}` : "cours";
// Le fil d'Ariane remonte AU COURS (la série), pas à l'index plat ; un cours
// autonome remonte à l'index.
const crumbHref = mod ? `${base}/cours/serie/${mod.serie}/` : `${base}/cours/`;
const serieNav = serieItems
  ? { items: serieItems.map((m) => ({ href: `${base}/cours/${m.id}/`, title: m.title, num: m.num })), current: serieIndex }
  : undefined;
---
<Reading
  title={d.title}
  description={d.description}
  crumb={{ href: crumbHref, label: crumbLabel }}
  badges={badges}
  lead={d.description}
  provenance={d.provenance}
  status={d.status}
  terminal={d.terminal}
  terminalTitle={d.terminalTitle}
  terminalComment={d.terminalComment}
  toc={toc}
  serieNav={serieNav}
  altUrl={hasEn ? `${base}/en/cours/${entry.id}/` : undefined}
  prev={prevEntry
    ? { href: `${base}/cours/${prevEntry.id}/`, label: prevEntry.data.title }
    : { href: `${base}/cours/`, label: "Tous les cours" }}
  next={nextEntry
    ? { href: `${base}/cours/${nextEntry.id}/`, label: `Module suivant : ${nextEntry.data.title}` }
    : { href: `${base}/cours/`, label: "Tous les cours" }}
>
  <Content components={mdxComponents} />
</Reading>
