---
import { getCollection, render } from "astro:content";
import Reading from "../../layouts/Reading.astro";
import { mdxComponents } from "../../components/mdx";

export async function getStaticPaths() {
  const cours = (await getCollection("cours", ({ data }) => !data.draft))
    .sort((a, b) => a.data.order - b.data.order);
  return cours.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, prevEntry: cours[i - 1] ?? null, nextEntry: cours[i + 1] ?? null },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const d = entry.data;
const badges = [d.badge, d.duration ? `≈ ${d.duration} min` : null].filter(Boolean) as string[];
---
<Reading
  title={d.title}
  description={d.description}
  crumb={{ href: `${base}/cours/`, label: `module ${String(d.order).padStart(2, "0")}` }}
  badges={badges}
  lead={d.description}
  terminal={d.terminal}
  terminalTitle={d.terminalTitle}
  terminalComment={d.terminalComment}
  prev={prevEntry
    ? { href: `${base}/cours/${prevEntry.id}/`, label: prevEntry.data.title }
    : { href: `${base}/cours/`, label: "Tous les cours" }}
  next={nextEntry
    ? { href: `${base}/cours/${nextEntry.id}/`, label: `Cours suivant : ${nextEntry.data.title}` }
    : { href: `${base}/cours/`, label: "Tous les cours" }}
>
  <Content components={mdxComponents} />
</Reading>
